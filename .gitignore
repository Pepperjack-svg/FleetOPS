# ===============================
# 🧭 FleetOps Git Ignore Template
# ===============================

# Node / Next.js
node_modules/
.next/
out/
dist/
.nitro/
.vercel/
.turbo/
.turbopack/

# TypeScript
*.tsbuildinfo

# Environment files
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# SQLite Database + backups
db/*.db
db/*.sqlite
db/*.sqlite3
db/*.db-shm
db/*.db-wal

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Local editor settings
.vscode/
.idea/
*.swp
*.swo

# OS metadata
.DS_Store
Thumbs.db

# Test and coverage output
coverage/
*.lcov

# Build artifacts
*.out
*.zip
*.tar.gz

# Next.js static export output
out/

# Docker
docker-compose.override.yml
*.pid
docker-data/
volumes/
tmp/
.docker/

# FleetOps specific
# (prevents pushing local SSH keys and generated credentials)
ssh_keys/
private_keys/
*.pem
*.key

# Optional: ignore screenshots / previews
screenshots/
*.png
*.jpg
*.jpeg
*.webp

# Optional: ignore local scripts / test files
scripts/local/
